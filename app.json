{
  "expo": {
    "name": "FLOW Water",
    "slug": "flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flowwater",
    "icon": "./assets/flow-logo.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/flow-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B72"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E1B72",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/flow-logo.jpeg",
        "resizeMode": "contain",
        "backgroundColor": "#1E1B72"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.qelz_developer.flow"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eca264f5-2871-4aa2-a7e0-46909e0f1db2"
      }
    },
    "owner": "qelz_developer"
  }
}
